{
  "name": "key_marketplace",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "admin": {
            "password": "11",
            "roles": [
              "Admin"
            ]
          },
          "salman": {
            "password": "11",
            "roles": [
              "SalesManager"
            ]
          },
          "supagent": {
            "password": "11",
            "roles": [
              "SupportAgent"
            ]
          }
        }
      },
      "db": {
        "kind": "sqlite"
      }
    },
    "csv": {
      "separator": ";"
    }
  }
}
