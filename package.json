{
  "name": "key_marketplace",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "axios": "^1.15.0",
    "jest": "^30.3.0"
  },
  "scripts": {
    "start": "cds run",
    "watch": "cds watch",
    "test": "jest"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "user": {
            "password": "11",
            "roles": [
              "authenticated-user"
            ]
          },
          "admin": {
            "password": "11",
            "roles": [
              "Admin"
            ]
          },
          "salman": {
            "password": "11",
            "roles": [
              "SalesManager"
            ]
          },
          "supagent": {
            "password": "11",
            "roles": [
              "SupportAgent"
            ]
          }
        }
      },
      "db": {
        "kind": "sqlite"
      },
      "[production]": {
        "db": {
          "kind": "hana"
        },
        "auth": {
          "kind": "xsuaa"
        }
      }
    },
    "csv": {
      "separator": ";"
    }
  }
}
